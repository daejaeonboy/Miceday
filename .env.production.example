# Cafe24 static hosting calls the active Firebase Function directly.
VITE_SITE_EMAIL_API_URL=https://us-central1-human-partner.cloudfunctions.net/sendEmailVerification

# Optional: only needed if admin features depend on an external API server.
# VITE_API_URL=https://your-api-domain.example.com

# Optional: comma-separated bootstrap admin emails.
# In production, only these emails can auto-create and auto-approve an admin profile.
# VITE_ADMIN_BOOTSTRAP_EMAILS=micepartner@micepartner.co.kr
